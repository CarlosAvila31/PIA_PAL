<?xml version="1.0" encoding="utf-8"?>
<Window
    x:Class="EXPERIMENTO.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:EXPERIMENTO"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
    Title="CineLobo">

    <Window.SystemBackdrop>
        <MicaBackdrop />
    </Window.SystemBackdrop>

    <Grid>
        <Grid.Background>
            <SolidColorBrush Color="#0D0D0D" />
        </Grid.Background>

        <Grid.ColumnDefinitions>
            <!-- Sidebar -->
            <ColumnDefinition Width="220" />
            <!-- Contenido principal -->
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <!-- ═══════════════════════════════════════════ -->
        <!-- SIDEBAR                                     -->
        <!-- ═══════════════════════════════════════════ -->
        <Border Grid.Column="0"
                Background="#141414"
                BorderBrush="#2A2A2A"
                BorderThickness="0,0,1,0">

            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <!-- Logo -->
                <Border Grid.Row="0" Padding="24,28,24,24">
                    <StackPanel Orientation="Horizontal" Spacing="10">
                        <TextBlock Text="🐺"
                                   FontSize="26"
                                   VerticalAlignment="Center" />
                        <TextBlock Text="CineLobo"
                                   FontSize="20"
                                   FontWeight="Bold"
                                   Foreground="#F5C842"
                                   VerticalAlignment="Center"
                                   CharacterSpacing="20" />
                    </StackPanel>
                </Border>

                <!-- Separador -->
                <Rectangle Grid.Row="0"
                           Height="1"
                           Fill="#2A2A2A"
                           VerticalAlignment="Bottom"
                           Margin="0,0,0,0" />

                <!-- Menú de navegación -->
                <StackPanel Grid.Row="1"
                            Margin="12,20,12,0"
                            Spacing="4">

                    <!-- Cartelera (activo por defecto) -->
                    <Button x:Name="BtnCartelera"
                            HorizontalAlignment="Stretch"
                            HorizontalContentAlignment="Left"
                            Click="BtnCartelera_Click"
                            Background="#2A2200"
                            Foreground="#F5C842"
                            BorderThickness="0"
                            CornerRadius="8"
                            Padding="14,12">
                        <StackPanel Orientation="Horizontal" Spacing="12">
                            <TextBlock Text="🎬" FontSize="16" VerticalAlignment="Center" />
                            <TextBlock Text="Cartelera"
                                       FontSize="14"
                                       FontWeight="SemiBold"
                                       VerticalAlignment="Center" />
                        </StackPanel>
                    </Button>

                    <!-- Mis Boletos -->
                    <Button x:Name="BtnMisBoletos"
                            HorizontalAlignment="Stretch"
                            HorizontalContentAlignment="Left"
                            Click="BtnMisBoletos_Click"
                            Background="Transparent"
                            Foreground="#8A8A8A"
                            BorderThickness="0"
                            CornerRadius="8"
                            Padding="14,12">
                        <StackPanel Orientation="Horizontal" Spacing="12">
                            <TextBlock Text="🎟️" FontSize="16" VerticalAlignment="Center" />
                            <TextBlock Text="Mis boletos"
                                       FontSize="14"
                                       VerticalAlignment="Center" />
                        </StackPanel>
                    </Button>

                    <!-- Mi Cuenta -->
                    <Button x:Name="BtnMiCuenta"
                            HorizontalAlignment="Stretch"
                            HorizontalContentAlignment="Left"
                            Click="BtnMiCuenta_Click"
                            Background="Transparent"
                            Foreground="#8A8A8A"
                            BorderThickness="0"
                            CornerRadius="8"
                            Padding="14,12">
                        <StackPanel Orientation="Horizontal" Spacing="12">
                            <TextBlock Text="👤" FontSize="16" VerticalAlignment="Center" />
                            <TextBlock Text="Mi cuenta"
                                       FontSize="14"
                                       VerticalAlignment="Center" />
                        </StackPanel>
                    </Button>

                </StackPanel>

                <!-- Ajustes (abajo del sidebar) -->
                <Border Grid.Row="2"
                        Padding="12,12,12,24"
                        BorderBrush="#2A2A2A"
                        BorderThickness="0,1,0,0">
                    <Button x:Name="BtnAjustes"
                            HorizontalAlignment="Stretch"
                            HorizontalContentAlignment="Left"
                            Click="BtnAjustes_Click"
                            Background="Transparent"
                            Foreground="#8A8A8A"
                            BorderThickness="0"
                            CornerRadius="8"
                            Padding="14,12">
                        <StackPanel Orientation="Horizontal" Spacing="12">
                            <TextBlock Text="⚙️" FontSize="16" VerticalAlignment="Center" />
                            <TextBlock Text="Ajustes"
                                       FontSize="14"
                                       VerticalAlignment="Center" />
                        </StackPanel>
                    </Button>
                </Border>

            </Grid>
        </Border>

        <!-- ═══════════════════════════════════════════ -->
        <!-- ÁREA DE CONTENIDO (Frame de navegación)     -->
        <!-- ═══════════════════════════════════════════ -->
        <Frame x:Name="ContentFrame"
               Grid.Column="1"
               Background="Transparent" />

    </Grid>
</Window>
