<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="EXPERIMENTO.Views.CartelerapPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:Models="using:EXPERIMENTO.Models"
    Background="Transparent">

    <ScrollViewer VerticalScrollBarVisibility="Auto"
                  HorizontalScrollBarVisibility="Disabled">
        <StackPanel Padding="36,32,36,36" Spacing="0">

            <!-- ENCABEZADO -->
            <TextBlock Text="Cartelera"
                       FontSize="28"
                       FontWeight="Bold"
                       Foreground="White" />
            <TextBlock Text="Selecciona una película para ver más detalles y comprar tus boletos"
                       FontSize="13"
                       Foreground="#6A6A6A"
                       Margin="0,4,0,32" />

            <!-- EN CARTELERA -->
            <TextBlock Text="EN CARTELERA"
                       FontSize="11"
                       FontWeight="SemiBold"
                       Foreground="#5A5A5A"
                       CharacterSpacing="120"
                       Margin="0,0,0,16" />

            <ItemsControl x:Name="ItemsEnCartelera" IsTabStop="False">
                <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate>
                        <ItemsWrapGrid MaximumRowsOrColumns="4" Orientation="Horizontal" />
                    </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>

                <ItemsControl.ItemTemplate>
                    <DataTemplate x:DataType="Models:Pelicula">
                        <Button Click="MovieCard_Click"
                                Tag="{x:Bind Id}"
                                Background="Transparent"
                                BorderThickness="0"
                                Padding="0"
                                CornerRadius="10">
                            <StackPanel Margin="10">
                                <TextBlock Text="{x:Bind Titulo}" 
                                           FontSize="14" 
                                           FontWeight="SemiBold" 
                                           Foreground="White"/>
                                <TextBlock Text="{x:Bind Director}" 
                                           FontSize="11" 
                                           Foreground="Gray"/>
                                <TextBlock Text="{x:Bind FechaEstreno}" 
                                           FontSize="11" 
                                           Foreground="LightGray"/>
                            </StackPanel>
                        </Button>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>

            <!-- PRÓXIMAMENTE -->
            <TextBlock Text="PRÓXIMAMENTE"
                       FontSize="11"
                       FontWeight="SemiBold"
                       Foreground="#5A5A5A"
                       CharacterSpacing="120"
                       Margin="0,40,0,16" />

            <ItemsControl x:Name="ItemsProximamente" IsTabStop="False">
                <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate>
                        <ItemsWrapGrid MaximumRowsOrColumns="4" Orientation="Horizontal" />
                    </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>

                <ItemsControl.ItemTemplate>
                    <DataTemplate x:DataType="Models:Pelicula">
                        <Button Click="MovieCard_Click"
                                Tag="{x:Bind Id}"
                                Background="Transparent"
                                BorderThickness="0"
                                Padding="0"
                                CornerRadius="10">
                            <StackPanel Margin="10">
                                <TextBlock Text="{x:Bind Titulo}" 
                                           FontSize="14" 
                                           FontWeight="SemiBold" 
                                           Foreground="White"/>
                                <TextBlock Text="{x:Bind Director}" 
                                           FontSize="11" 
                                           Foreground="Gray"/>
                                <TextBlock Text="{x:Bind FechaEstreno}" 
                                           FontSize="11" 
                                           Foreground="LightGray"/>
                            </StackPanel>
                        </Button>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>

        </StackPanel>
    </ScrollViewer>
</Page>
