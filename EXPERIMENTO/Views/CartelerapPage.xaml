<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="EXPERIMENTO.Views.CartelerapPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:Models="using:EXPERIMENTO.Models"
    Background="Transparent">

    <ScrollViewer VerticalScrollBarVisibility="Auto"
                  HorizontalScrollBarVisibility="Disabled">
        <StackPanel Padding="36,32,36,36" Spacing="0">

            <!-- ENCABEZADO -->
            <TextBlock Text="Cartelera"
                       FontSize="28"
                       FontWeight="Bold"
                       Foreground="White" />
            <TextBlock Text="Selecciona una película para ver más detalles y comprar tus boletos"
                       FontSize="13"
                       Foreground="#6A6A6A"
                       Margin="0,4,0,32" />

            <!-- EN CARTELERA -->
            <TextBlock Text="EN CARTELERA"
                       FontSize="11"
                       FontWeight="SemiBold"
                       Foreground="#5A5A5A"
                       CharacterSpacing="120"
                       Margin="0,0,0,16" />

            <ItemsControl x:Name="ItemsEnCartelera" IsTabStop="False">
                <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate>
                        <ItemsWrapGrid MaximumRowsOrColumns="4" Orientation="Horizontal" />
                    </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>

                <ItemsControl.ItemTemplate>
                    <DataTemplate x:DataType="Models:Pelicula">
                        <Button Click="MovieCard_Click"
                                Tag="{x:Bind Id}"
                                HorizontalContentAlignment="Stretch"
                                Background="Transparent"
                                BorderThickness="0"
                                Padding="8"
                                CornerRadius="10">
                            <Border CornerRadius="10"
                                    Background="#1A1A1A"
                                    BorderBrush="#2A2A2A"
                                    BorderThickness="1"
                                    Width="220">
                                <StackPanel>
                                    <!-- Poster -->
                                    <Border Height="300"
                                            CornerRadius="10,10,0,0"

                                            Background="#111111">
                                        <Grid>
                                            <TextBlock Text="🎬"
                                                       FontSize="52"
                                                       HorizontalAlignment="Center"
                                                       VerticalAlignment="Center" />
                                            <Image Source="{x:Bind RutaPoster}"
                                                   Stretch="UniformToFill" />
                                        </Grid>
                                    </Border>

                                    <!-- Info -->
                                    <StackPanel Padding="14,12,14,14" Spacing="6">
                                        <TextBlock Text="{x:Bind Titulo}"
                                                   FontSize="14"
                                                   FontWeight="SemiBold"
                                                   Foreground="White"
                                                   TextTrimming="CharacterEllipsis" />
                                        <StackPanel Orientation="Horizontal" Spacing="6">
                                            <TextBlock Text="{x:Bind DuracionMinutos}"
                                                       FontSize="11"
                                                       Foreground="#5A5A5A" />
                                            <Border Background="#2A2A2A" CornerRadius="4" Padding="6,2">
                                                <TextBlock Text="{x:Bind Clasificacion}"
                                                           FontSize="10"
                                                           Foreground="#8A8A8A" />
                                            </Border>
                                        </StackPanel>
                                    </StackPanel>
                                </StackPanel>
                            </Border>
                        </Button>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>

            <!-- PRÓXIMAMENTE -->
            <TextBlock Text="PRÓXIMAMENTE"
                       FontSize="11"
                       FontWeight="SemiBold"
                       Foreground="#5A5A5A"
                       CharacterSpacing="120"
                       Margin="0,40,0,16" />

            <ItemsControl x:Name="ItemsProximamente" IsTabStop="False">
                <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate>
                        <ItemsWrapGrid MaximumRowsOrColumns="4" Orientation="Horizontal" />
                    </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>

                <ItemsControl.ItemTemplate>
                    <DataTemplate x:DataType="Models:Pelicula">
                        <Button Click="MovieCard_Click"
                                Tag="{x:Bind Id}"
                                HorizontalContentAlignment="Stretch"
                                Background="Transparent"
                                BorderThickness="0"
                                Padding="8"
                                CornerRadius="10">
                            <Border CornerRadius="10"
                                    Background="#1A1A1A"
                                    BorderBrush="#2A2A2A"
                                    BorderThickness="1"
                                    Width="220">
                                <StackPanel>
                                    <!-- Poster -->
                                    <Border Height="300"
                                            CornerRadius="10,10,0,0"
                                            Background="#111111">
                                        <Grid>
                                            <TextBlock Text="🎬"
                                                       FontSize="52"
                                                       HorizontalAlignment="Center"
                                                       VerticalAlignment="Center" />
                                            <Image Source="{x:Bind RutaPoster}"
                                                   Stretch="UniformToFill" />
                                        </Grid>
                                    </Border>

                                    <!-- Info -->
                                    <StackPanel Padding="14,12,14,14" Spacing="6">
                                        <TextBlock Text="{x:Bind Titulo}"
                                                   FontSize="14"
                                                   FontWeight="SemiBold"
                                                   Foreground="White"
                                                   TextTrimming="CharacterEllipsis" />
                                        <StackPanel Orientation="Horizontal" Spacing="6">
                                            <TextBlock Text="{x:Bind FechaEstreno}"
                                                       FontSize="11"
                                                       Foreground="#F5C842" />
                                            <Border Background="#2A2A2A" CornerRadius="4" Padding="6,2">
                                                <TextBlock Text="{x:Bind Clasificacion}"
                                                           FontSize="10"
                                                           Foreground="#8A8A8A" />
                                            </Border>
                                        </StackPanel>
                                    </StackPanel>
                                </StackPanel>
                            </Border>
                        </Button>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>

        </StackPanel>
    </ScrollViewer>
</Page>
