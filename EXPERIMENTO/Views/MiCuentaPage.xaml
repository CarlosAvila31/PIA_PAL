<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="EXPERIMENTO.Views.MiCuentaPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Background="Transparent">

    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel HorizontalAlignment="Center"
                    VerticalAlignment="Center"
                    MaxWidth="400"
                    Padding="24,48,24,48"
                    Spacing="0">

            <!-- ══ VISTA: NO LOGUEADO ══════════════════════════════════════ -->
            <StackPanel x:Name="PanelAuth" Visibility="Visible" Spacing="0">

                <!-- Header -->
                <TextBlock Text="👤"
                           FontSize="52"
                           HorizontalAlignment="Center"
                           Margin="0,0,0,12"/>
                <TextBlock x:Name="TituloAuthText"
                           Text="Iniciar sesión"
                           FontSize="26" FontWeight="Bold"
                           Foreground="White"
                           HorizontalAlignment="Center"
                           Margin="0,0,0,6"/>
                <TextBlock x:Name="SubtituloAuthText"
                           Text="Accede a tu cuenta para ver tus boletos"
                           FontSize="13"
                           Foreground="#5A5A5A"
                           HorizontalAlignment="Center"
                           TextAlignment="Center"
                           Margin="0,0,0,36"/>

                <!-- Campo Nombre (solo registro) -->
                <StackPanel x:Name="CampoNombrePanel" Visibility="Collapsed" Margin="0,0,0,14">
                    <TextBlock Text="NOMBRE" FontSize="10" FontWeight="SemiBold"
                               Foreground="#5A5A5A" CharacterSpacing="80" Margin="0,0,0,6"/>
                    <TextBox x:Name="NombreBox"
                             PlaceholderText="Tu nombre"
                             Background="#1A1A1A"
                             Foreground="White"
                             BorderBrush="#3A3A3A"
                             BorderThickness="1"
                             CornerRadius="8"
                             Padding="14,12"
                             FontSize="14"/>
                </StackPanel>

                <!-- Campo Email -->
                <StackPanel Margin="0,0,0,14">
                    <TextBlock Text="CORREO ELECTRÓNICO" FontSize="10" FontWeight="SemiBold"
                               Foreground="#5A5A5A" CharacterSpacing="80" Margin="0,0,0,6"/>
                    <TextBox x:Name="EmailBox"
                             PlaceholderText="correo@ejemplo.com"
                             Background="#1A1A1A"
                             Foreground="White"
                             BorderBrush="#3A3A3A"
                             BorderThickness="1"
                             CornerRadius="8"
                             Padding="14,12"
                             FontSize="14"/>
                </StackPanel>

                <!-- Campo Contraseña -->
                <StackPanel Margin="0,0,0,24">
                    <TextBlock Text="CONTRASEÑA" FontSize="10" FontWeight="SemiBold"
                               Foreground="#5A5A5A" CharacterSpacing="80" Margin="0,0,0,6"/>
                    <PasswordBox x:Name="PasswordBox"
                                 PlaceholderText="••••••••"
                                 Background="#1A1A1A"
                                 Foreground="White"
                                 BorderBrush="#3A3A3A"
                                 BorderThickness="1"
                                 CornerRadius="8"
                                 Padding="14,12"
                                 FontSize="14"/>
                </StackPanel>

                <!-- Mensaje de error/éxito -->
                <TextBlock x:Name="MensajeText"
                           Text=""
                           FontSize="13"
                           Foreground="#E05555"
                           HorizontalAlignment="Center"
                           TextAlignment="Center"
                           Visibility="Collapsed"
                           Margin="0,0,0,16"
                           TextWrapping="Wrap"/>

                <!-- Botón principal -->
                <Button x:Name="BtnPrincipal"
                        Content="Iniciar sesión"
                        Click="BtnPrincipal_Click"
                        HorizontalAlignment="Stretch"
                        Background="#F5C842"
                        Foreground="#0D0D0D"
                        FontWeight="SemiBold"
                        FontSize="15"
                        BorderThickness="0"
                        CornerRadius="10"
                        Padding="0,14"
                        Margin="0,0,0,16"/>

                <!-- Separador -->
                <Grid Margin="0,0,0,16">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <Rectangle Grid.Column="0" Height="1" Fill="#2A2A2A" VerticalAlignment="Center"/>
                    <TextBlock Grid.Column="1" Text=" o " FontSize="12" Foreground="#5A5A5A" Margin="8,0"/>
                    <Rectangle Grid.Column="2" Height="1" Fill="#2A2A2A" VerticalAlignment="Center"/>
                </Grid>

                <!-- Cambiar modo -->
                <Button x:Name="BtnCambiarModo"
                        Click="BtnCambiarModo_Click"
                        HorizontalAlignment="Stretch"
                        Background="Transparent"
                        Foreground="#8A8A8A"
                        BorderBrush="#3A3A3A"
                        BorderThickness="1"
                        CornerRadius="10"
                        Padding="0,12"
                        FontSize="14">
                    <TextBlock x:Name="BtnCambiarModoText"
                               Text="¿No tienes cuenta? Regístrate"
                               HorizontalAlignment="Center"/>
                </Button>

            </StackPanel>

            <!-- ══ VISTA: LOGUEADO ═════════════════════════════════════════ -->
            <StackPanel x:Name="PanelPerfil" Visibility="Collapsed" Spacing="0">

                <!-- Avatar -->
                <Border Width="80" Height="80" CornerRadius="40"
                        Background="#F5C842"
                        HorizontalAlignment="Center"
                        Margin="0,0,0,16">
                    <TextBlock x:Name="AvatarText"
                               Text="?"
                               FontSize="32" FontWeight="Bold"
                               Foreground="#0D0D0D"
                               HorizontalAlignment="Center"
                               VerticalAlignment="Center"/>
                </Border>

                <TextBlock x:Name="NombrePerfilText"
                           Text=""
                           FontSize="22" FontWeight="Bold"
                           Foreground="White"
                           HorizontalAlignment="Center"
                           Margin="0,0,0,4"/>

                <TextBlock x:Name="EmailPerfilText"
                           Text=""
                           FontSize="13"
                           Foreground="#5A5A5A"
                           HorizontalAlignment="Center"
                           Margin="0,0,0,32"/>

                <!-- Tarjeta de stats -->
                <Border Background="#141414"
                        BorderBrush="#2A2A2A"
                        BorderThickness="1"
                        CornerRadius="12"
                        Padding="24,20"
                        Margin="0,0,0,24">
                    <StackPanel Spacing="0">
                        <TextBlock Text="RESUMEN" FontSize="10" FontWeight="SemiBold"
                                   Foreground="#5A5A5A" CharacterSpacing="80"
                                   Margin="0,0,0,14"/>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel HorizontalAlignment="Center">
                                <TextBlock x:Name="TotalBoletosText"
                                           Text="0"
                                           FontSize="28" FontWeight="Bold"
                                           Foreground="#F5C842"
                                           HorizontalAlignment="Center"/>
                                <TextBlock Text="Boletos"
                                           FontSize="12" Foreground="#5A5A5A"
                                           HorizontalAlignment="Center"/>
                            </StackPanel>
                            <StackPanel Grid.Column="1" HorizontalAlignment="Center">
                                <TextBlock x:Name="TotalGastadoText"
                                           Text="$0"
                                           FontSize="28" FontWeight="Bold"
                                           Foreground="#F5C842"
                                           HorizontalAlignment="Center"/>
                                <TextBlock Text="Gastado"
                                           FontSize="12" Foreground="#5A5A5A"
                                           HorizontalAlignment="Center"/>
                            </StackPanel>
                        </Grid>
                    </StackPanel>
                </Border>

                <!-- Botón cerrar sesión -->
                <Button x:Name="BtnLogout"
                        Content="Cerrar sesión"
                        Click="BtnLogout_Click"
                        HorizontalAlignment="Stretch"
                        Background="Transparent"
                        Foreground="#E05555"
                        BorderBrush="#3A3A3A"
                        BorderThickness="1"
                        CornerRadius="10"
                        Padding="0,12"
                        FontSize="14"/>

            </StackPanel>

        </StackPanel>
    </ScrollViewer>
</Page>
