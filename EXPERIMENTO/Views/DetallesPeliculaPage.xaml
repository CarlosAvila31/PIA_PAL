<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="EXPERIMENTO.Views.DetallesPeliculaPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Background="Transparent">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="56" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!-- ══════════════════════════════════════════════════════ -->
        <!-- STEPPER DE PASOS                                      -->
        <!-- ══════════════════════════════════════════════════════ -->
        <Border Grid.Row="0"
                Background="#141414"
                BorderBrush="#2A2A2A"
                BorderThickness="0,0,0,1">
            <Grid HorizontalAlignment="Stretch" VerticalAlignment="Center">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <!-- Paso 1: Detalle (activo) -->
                <StackPanel Grid.Column="0" Orientation="Horizontal"
                            HorizontalAlignment="Center" Spacing="10">
                    <Border Width="26" Height="26" CornerRadius="13" Background="#F5C842">
                        <TextBlock Text="1" FontSize="12" FontWeight="Bold" Foreground="#0D0D0D"
                                   HorizontalAlignment="Center" VerticalAlignment="Center" />
                    </Border>
                    <TextBlock Text="Detalle" FontSize="13" FontWeight="SemiBold"
                               Foreground="#F5C842" VerticalAlignment="Center" />
                </StackPanel>

                <!-- Paso 2: Horario -->
                <StackPanel Grid.Column="1" Orientation="Horizontal"
                            HorizontalAlignment="Center" Spacing="10">
                    <Border Width="26" Height="26" CornerRadius="13"
                            Background="Transparent" BorderBrush="#3A3A3A" BorderThickness="1">
                        <TextBlock Text="2" FontSize="12" Foreground="#5A5A5A"
                                   HorizontalAlignment="Center" VerticalAlignment="Center" />
                    </Border>
                    <TextBlock Text="Horario" FontSize="13" Foreground="#5A5A5A"
                               VerticalAlignment="Center" />
                </StackPanel>

                <!-- Paso 3: Asientos -->
                <StackPanel Grid.Column="2" Orientation="Horizontal"
                            HorizontalAlignment="Center" Spacing="10">
                    <Border Width="26" Height="26" CornerRadius="13"
                            Background="Transparent" BorderBrush="#3A3A3A" BorderThickness="1">
                        <TextBlock Text="3" FontSize="12" Foreground="#5A5A5A"
                                   HorizontalAlignment="Center" VerticalAlignment="Center" />
                    </Border>
                    <TextBlock Text="Asientos" FontSize="13" Foreground="#5A5A5A"
                               VerticalAlignment="Center" />
                </StackPanel>

                <!-- Paso 4: Confirmar -->
                <StackPanel Grid.Column="3" Orientation="Horizontal"
                            HorizontalAlignment="Center" Spacing="10">
                    <Border Width="26" Height="26" CornerRadius="13"
                            Background="Transparent" BorderBrush="#3A3A3A" BorderThickness="1">
                        <TextBlock Text="4" FontSize="12" Foreground="#5A5A5A"
                                   HorizontalAlignment="Center" VerticalAlignment="Center" />
                    </Border>
                    <TextBlock Text="Confirmar" FontSize="13" Foreground="#5A5A5A"
                               VerticalAlignment="Center" />
                </StackPanel>
            </Grid>
        </Border>

        <!-- ══════════════════════════════════════════════════════ -->
        <!-- CONTENIDO PRINCIPAL                                   -->
        <!-- ══════════════════════════════════════════════════════ -->
        <ScrollViewer Grid.Row="1"
                      VerticalScrollBarVisibility="Auto"
                      HorizontalScrollBarVisibility="Disabled">
            <StackPanel Padding="36,28,36,36">

                <!-- Botón volver -->
                <Button x:Name="BtnVolver"
                        Click="BtnVolver_Click"
                        Background="Transparent"
                        Foreground="#8A8A8A"
                        BorderThickness="0"
                        Padding="0"
                        Margin="0,0,0,28"
                        HorizontalAlignment="Left">
                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <TextBlock Text="←" FontSize="14" VerticalAlignment="Center" />
                        <TextBlock Text="Volver a cartelera" FontSize="13" VerticalAlignment="Center" />
                    </StackPanel>
                </Button>

                <!-- Layout: Poster + Info -->
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="280" />
                        <ColumnDefinition Width="36" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>

                    <!-- ══ POSTER ══
                         Grid apilado: primero el fondo oscuro + emoji (fallback),
                         encima la Image real. Si la imagen carga, tapa el emoji.
                         Si no hay archivo, queda el emoji visible. -->
                    <Border Grid.Column="0"
                            CornerRadius="12"
                            Height="380"
                            VerticalAlignment="Top"
                            Background="#1A1A1A"
                            BorderBrush="#2A2A2A"
                            BorderThickness="1"
                            >
                        <Grid>
                            <!-- Fallback: emoji centrado -->
                            <TextBlock x:Name="PosterEmoji"
                                       Text="🎬"
                                       FontSize="72"
                                       HorizontalAlignment="Center"
                                       VerticalAlignment="Center" />
                            <!-- Imagen real del poster -->
                            <Image x:Name="PosterImage"
                                   Stretch="UniformToFill"
                                   HorizontalAlignment="Center"
                                   VerticalAlignment="Center"
                                   ImageOpened="PosterImage_ImageOpened"
                                   ImageFailed="PosterImage_ImageFailed" />
                        </Grid>
                    </Border>

                    <!-- ══ INFO ══ -->
                    <StackPanel Grid.Column="2" VerticalAlignment="Top" Spacing="0">

                        <!-- Título -->
                        <TextBlock x:Name="TituloText"
                                   FontSize="30"
                                   FontWeight="Bold"
                                   Foreground="White"
                                   Margin="0,0,0,10" />

                        <!-- Estrellas + reseñas -->
                        <StackPanel Orientation="Horizontal" Spacing="10" Margin="0,0,0,16">
                            <TextBlock x:Name="EstrellasText"
                                       FontSize="18"
                                       Foreground="#F5C842"
                                       VerticalAlignment="Center" />
                            <TextBlock x:Name="CalificacionText"
                                       FontSize="13"
                                       Foreground="#8A8A8A"
                                       VerticalAlignment="Center" />
                        </StackPanel>

                        <!-- Chips de géneros -->
                        <StackPanel x:Name="GenerosPanel"
                                    Orientation="Horizontal"
                                    Spacing="8"
                                    Margin="0,0,0,24" />

                        <!-- Duración · Clasificación · Estreno -->
                        <Grid Margin="0,0,0,20">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="48" />
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="48" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>

                            <StackPanel Grid.Column="0" Spacing="4">
                                <TextBlock Text="DURACIÓN" FontSize="10" FontWeight="SemiBold"
                                           Foreground="#5A5A5A" CharacterSpacing="80" />
                                <TextBlock x:Name="DuracionText" FontSize="14" Foreground="White" />
                            </StackPanel>

                            <StackPanel Grid.Column="2" Spacing="4">
                                <TextBlock Text="CLASIFICACIÓN" FontSize="10" FontWeight="SemiBold"
                                           Foreground="#5A5A5A" CharacterSpacing="80" />
                                <TextBlock x:Name="ClasificacionText" FontSize="14" Foreground="White" />
                            </StackPanel>

                            <StackPanel Grid.Column="4" Spacing="4">
                                <TextBlock Text="ESTRENO" FontSize="10" FontWeight="SemiBold"
                                           Foreground="#5A5A5A" CharacterSpacing="80" />
                                <TextBlock x:Name="EstrenoText" FontSize="14" Foreground="White" />
                            </StackPanel>
                        </Grid>

                        <!-- Director -->
                        <StackPanel Spacing="4" Margin="0,0,0,14">
                            <TextBlock Text="DIRECTOR" FontSize="10" FontWeight="SemiBold"
                                       Foreground="#5A5A5A" CharacterSpacing="80" />
                            <TextBlock x:Name="DirectorText" FontSize="14" Foreground="White" />
                        </StackPanel>

                        <!-- Reparto -->
                        <StackPanel Spacing="4" Margin="0,0,0,20">
                            <TextBlock Text="REPARTO" FontSize="10" FontWeight="SemiBold"
                                       Foreground="#5A5A5A" CharacterSpacing="80" />
                            <TextBlock x:Name="RepartoText" FontSize="14" Foreground="White" />
                        </StackPanel>

                        <!-- Sinopsis -->
                        <TextBlock x:Name="SinopsisText"
                                   FontSize="13"
                                   Foreground="#8A8A8A"
                                   TextWrapping="Wrap"
                                   LineHeight="22"
                                   Margin="0,0,0,24" />


                        <!-- Botones -->
                        <StackPanel Orientation="Horizontal" Spacing="12">
                            <Button x:Name="BtnComprar"
                                    Content="Comprar boletos"
                                    Click="BtnComprar_Click"
                                    Background="#F5C842"
                                    Foreground="#0D0D0D"
                                    FontWeight="SemiBold"
                                    BorderThickness="0"
                                    CornerRadius="8"
                                    Padding="28,12"
                                    FontSize="14" />
                            <Button x:Name="BtnTrailer"
                                    Content="▶  Trailer"
                                    Click="BtnTrailer_Click"
                                    Background="#1E1E1E"
                                    Foreground="White"
                                    BorderBrush="#3A3A3A"
                                    BorderThickness="1"
                                    CornerRadius="8"
                                    Padding="20,12"
                                    FontSize="14" />
                        </StackPanel>

                    </StackPanel>
                </Grid>

            </StackPanel>
        </ScrollViewer>
    </Grid>
</Page>
