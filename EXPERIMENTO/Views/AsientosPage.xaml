<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="EXPERIMENTO.Views.AsientosPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Background="Transparent">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="56" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!-- STEPPER - paso 3 activo -->
        <Border Grid.Row="0"
                Background="#141414"
                BorderBrush="#2A2A2A"
                BorderThickness="0,0,0,1">
            <Grid HorizontalAlignment="Stretch" VerticalAlignment="Center">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <!-- Paso 1: Detalle (completado) -->
                <StackPanel Grid.Column="0" Orientation="Horizontal"
                            HorizontalAlignment="Center" Spacing="10">
                    <Border Width="26" Height="26" CornerRadius="13"
                            Background="#3A3A3A">
                        <TextBlock Text="✓" FontSize="12" FontWeight="Bold"
                                   Foreground="#F5C842"
                                   HorizontalAlignment="Center" VerticalAlignment="Center" />
                    </Border>
                    <TextBlock Text="Detalle" FontSize="13"
                               Foreground="#5A5A5A" VerticalAlignment="Center" />
                </StackPanel>

                <!-- Paso 2: Horario (completado) -->
                <StackPanel Grid.Column="1" Orientation="Horizontal"
                            HorizontalAlignment="Center" Spacing="10">
                    <Border Width="26" Height="26" CornerRadius="13" 
                            Background="#3A3A3A">
                        <TextBlock Text="✓" FontSize="12" FontWeight="Bold"
                                   Foreground="#F5C842"
                                   HorizontalAlignment="Center" VerticalAlignment="Center" />
                    </Border>
                    <TextBlock Text="Horario" FontSize="13" FontWeight="SemiBold"
                               Foreground="#5A5A5A" VerticalAlignment="Center" />
                </StackPanel>

                <!-- Paso 3: Asientos (activo) -->
                <StackPanel Grid.Column="2" Orientation="Horizontal"
                            HorizontalAlignment="Center" Spacing="10">
                    <Border Width="26" Height="26" CornerRadius="13"
                            Background="#F5C842" BorderBrush="#3A3A3A" BorderThickness="1">
                        <TextBlock Text="3" FontSize="12" FontWeight="Bold"
                                   Foreground="#0D0D0D" HorizontalAlignment="Center" VerticalAlignment="Center" />
                    </Border>
                    <TextBlock Text="Asientos" FontSize="13"
                               Foreground="#F5C842" VerticalAlignment="Center" />
                </StackPanel>

                <!-- Paso 4: Confirmar -->
                <StackPanel Grid.Column="3" Orientation="Horizontal"
                            HorizontalAlignment="Center" Spacing="10">
                    <Border Width="26" Height="26" CornerRadius="13"
                            Background="Transparent" BorderBrush="#3A3A3A" BorderThickness="1">
                        <TextBlock Text="4" FontSize="12" Foreground="#5A5A5A"
                                   HorizontalAlignment="Center" VerticalAlignment="Center" />
                    </Border>
                    <TextBlock Text="Confirmar" FontSize="13" Foreground="#5A5A5A"
                               VerticalAlignment="Center" />
                </StackPanel>
            </Grid>
        </Border>

        <!-- CONTENIDO -->
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="280" />
            </Grid.ColumnDefinitions>

            <!-- Mapa de asientos -->
            <ScrollViewer Grid.Column="0"
                          VerticalScrollBarVisibility="Auto"
                          HorizontalScrollBarVisibility="Auto">
                <StackPanel Padding="36,28,24,36"
                            HorizontalAlignment="Center"
                            Spacing="0">

                    <!-- Boton volver -->
                    <Button x:Name="BtnVolver"
                            Click="BtnVolver_Click"
                            Background="Transparent"
                            Foreground="#8A8A8A"
                            BorderThickness="0"
                            Padding="0"
                            Margin="0,0,0,24"
                            HorizontalAlignment="Left">
                        <StackPanel Orientation="Horizontal" Spacing="8">
                            <TextBlock Text="&lt;-" FontSize="14" VerticalAlignment="Center" />
                            <TextBlock Text="Volver a horarios" FontSize="13"
                                       VerticalAlignment="Center" />
                        </StackPanel>
                    </Button>

                    <!-- Info funcion -->
                    <TextBlock x:Name="InfoFuncionText"
                               FontSize="13" Foreground="#8A8A8A"
                               Margin="0,0,0,28" />

                    <!-- Pantalla -->
                    <Border Background="#2A2A2A"
                            CornerRadius="4"
                            Padding="0,8"
                            Margin="0,0,0,0"
                            HorizontalAlignment="Stretch">
                        <TextBlock Text="PANTALLA"
                                   FontSize="11" FontWeight="SemiBold"
                                   Foreground="#5A5A5A" CharacterSpacing="120"
                                   HorizontalAlignment="Center" />
                    </Border>

                    <!-- Degradado debajo de pantalla -->
                    <Border Height="20" Margin="20,0,20,24">
                        <Border.Background>
                            <LinearGradientBrush StartPoint="0.5,0" EndPoint="0.5,1">
                                <GradientStop Color="#442A2A2A" Offset="0" />
                                <GradientStop Color="#000D0D0D" Offset="1" />
                            </LinearGradientBrush>
                        </Border.Background>
                    </Border>

                    <!-- Mapa generado desde code-behind -->
                    <StackPanel x:Name="MapaAsientos"
                                Spacing="6"
                                HorizontalAlignment="Center" />

                    <!-- Leyenda -->
                    <StackPanel Orientation="Horizontal"
                                HorizontalAlignment="Center"
                                Spacing="24"
                                Margin="0,28,0,0">
                        <StackPanel Orientation="Horizontal" Spacing="8">
                            <Border Width="20" Height="20" CornerRadius="4"
                                    Background="#2A2A2A" BorderBrush="#3A3A3A" BorderThickness="1" />
                            <TextBlock Text="Disponible" FontSize="12" Foreground="#8A8A8A"
                                       VerticalAlignment="Center" />
                        </StackPanel>
                        <StackPanel Orientation="Horizontal" Spacing="8">
                            <Border Width="20" Height="20" CornerRadius="4"
                                    Background="#F5C842" />
                            <TextBlock Text="Seleccionado" FontSize="12" Foreground="#8A8A8A"
                                       VerticalAlignment="Center" />
                        </StackPanel>
                        <StackPanel Orientation="Horizontal" Spacing="8">
                            <Border Width="20" Height="20" CornerRadius="4"
                                    Background="#1A1A1A" BorderBrush="#2A2A2A" BorderThickness="1" />
                            <TextBlock Text="Ocupado" FontSize="12" Foreground="#8A8A8A"
                                       VerticalAlignment="Center" />
                        </StackPanel>
                    </StackPanel>

                </StackPanel>
            </ScrollViewer>

            <!-- Panel lateral de resumen -->
            <Border Grid.Column="1"
                    Background="#141414"
                    BorderBrush="#2A2A2A"
                    BorderThickness="1,0,0,0">
                <StackPanel Padding="24" Spacing="0" VerticalAlignment="Top">

                    <TextBlock Text="Tu seleccion"
                               FontSize="16" FontWeight="SemiBold"
                               Foreground="White" Margin="0,0,0,20" />

                    <TextBlock Text="ASIENTOS" FontSize="10" FontWeight="SemiBold"
                               Foreground="#5A5A5A" CharacterSpacing="80"
                               Margin="0,0,0,8" />

                    <TextBlock x:Name="AsientosSeleccionadosText"
                               Text="Ninguno"
                               FontSize="14" Foreground="White"
                               TextWrapping="Wrap"
                               Margin="0,0,0,24" />

                    <Rectangle Height="1" Fill="#2A2A2A" Margin="0,0,0,20" />

                    <Grid Margin="0,0,0,8">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="Boletos" FontSize="13" Foreground="#8A8A8A" />
                        <TextBlock x:Name="CantidadText" Grid.Column="1"
                                   Text="0" FontSize="13" Foreground="White" />
                    </Grid>

                    <Grid Margin="0,0,0,8">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="Precio c/u" FontSize="13" Foreground="#8A8A8A" />
                        <TextBlock x:Name="PrecioUnitarioText" Grid.Column="1"
                                   Text="$80.00" FontSize="13" Foreground="White" />
                    </Grid>

                    <Rectangle Height="1" Fill="#2A2A2A" Margin="0,8,0,12" />

                    <Grid Margin="0,0,0,28">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="Total" FontSize="15" FontWeight="SemiBold"
                                   Foreground="White" />
                        <TextBlock x:Name="TotalText" Grid.Column="1"
                                   Text="$0.00" FontSize="15" FontWeight="SemiBold"
                                   Foreground="#F5C842" />
                    </Grid>

                    <Button x:Name="BtnConfirmar"
                            Content="Confirmar compra"
                            Click="BtnConfirmar_Click"
                            HorizontalAlignment="Stretch"
                            IsEnabled="False"
                            Background="#F5C842"
                            Foreground="#0D0D0D"
                            FontWeight="SemiBold"
                            BorderThickness="0"
                            CornerRadius="8"
                            Padding="0,12"
                            FontSize="14" />

                </StackPanel>
            </Border>
        </Grid>
    </Grid>
</Page>
