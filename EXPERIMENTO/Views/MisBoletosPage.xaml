<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="EXPERIMENTO.Views.MisBoletosPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Background="Transparent">

    <Grid>

        <!-- ══ SIN SESIÓN ═══════════════════════════════════════════════════ -->
        <StackPanel x:Name="PanelSinSesion"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center"
                    Spacing="12"
                    Visibility="Collapsed">
            <TextBlock Text="🔒"
                       FontSize="52"
                       HorizontalAlignment="Center"/>
            <TextBlock Text="Inicia sesión para ver tus boletos"
                       FontSize="18" FontWeight="SemiBold"
                       Foreground="White"
                       HorizontalAlignment="Center"
                       TextAlignment="Center"/>
            <TextBlock Text="Ve a Mi Cuenta para registrarte o iniciar sesión."
                       FontSize="13"
                       Foreground="#5A5A5A"
                       HorizontalAlignment="Center"
                       TextAlignment="Center"/>
        </StackPanel>

        <!-- ══ CON SESIÓN PERO SIN BOLETOS ══════════════════════════════════ -->
        <StackPanel x:Name="PanelSinBoletos"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center"
                    Spacing="12"
                    Visibility="Collapsed">
            <TextBlock Text="🎟️"
                       FontSize="52"
                       HorizontalAlignment="Center"/>
            <TextBlock Text="Aún no tienes boletos"
                       FontSize="18" FontWeight="SemiBold"
                       Foreground="White"
                       HorizontalAlignment="Center"/>
            <TextBlock Text="Compra tus primeras entradas en la cartelera."
                       FontSize="13"
                       Foreground="#5A5A5A"
                       HorizontalAlignment="Center"/>
        </StackPanel>

        <!-- ══ LISTA DE BOLETOS ══════════════════════════════════════════════ -->
        <ScrollViewer x:Name="PanelBoletos"
                      Visibility="Collapsed"
                      VerticalScrollBarVisibility="Auto">
            <StackPanel Padding="32,28,32,32" Spacing="0">

                <TextBlock Text="Mis Boletos"
                           FontSize="24" FontWeight="Bold"
                           Foreground="White"
                           Margin="0,0,0,6"/>
                <TextBlock x:Name="SubtituloText"
                           Text=""
                           FontSize="13"
                           Foreground="#5A5A5A"
                           Margin="0,0,0,28"/>

                <!-- Cards de boletos (generadas en code-behind) -->
                <StackPanel x:Name="ListaBoletos" Spacing="16"/>

            </StackPanel>
        </ScrollViewer>

    </Grid>
</Page>
