<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="EXPERIMENTO.Views.ConfirmarPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Background="Transparent">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="56" />
            <!-- Stepper -->
            <RowDefinition Height="*" />
            <!-- Contenido -->
        </Grid.RowDefinitions>

        <!-- STEPPER - paso 4 activo -->
        <Border Grid.Row="0"
                Background="#141414"
                BorderBrush="#2A2A2A"
                BorderThickness="0,0,0,1">
            <Grid HorizontalAlignment="Stretch" VerticalAlignment="Center">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <!-- Paso 1: Detalle -->
                <StackPanel Grid.Column="0" Orientation="Horizontal"
                            HorizontalAlignment="Center" Spacing="10">
                    <Border Width="26" Height="26" CornerRadius="13"
                            Background="#3A3A3A">
                        <TextBlock Text="✓" FontSize="12" FontWeight="Bold"
                                   Foreground="#F5C842"
                                   HorizontalAlignment="Center" VerticalAlignment="Center" />
                    </Border>
                    <TextBlock Text="Detalle" FontSize="13"
                               Foreground="#5A5A5A" VerticalAlignment="Center" />
                </StackPanel>

                <!-- Paso 2: Horario -->
                <StackPanel Grid.Column="1" Orientation="Horizontal"
                            HorizontalAlignment="Center" Spacing="10">
                    <Border Width="26" Height="26" CornerRadius="13"
                            Background="#3A3A3A">
                        <TextBlock Text="✓" FontSize="12" FontWeight="Bold"
                                   Foreground="#F5C842"
                                   HorizontalAlignment="Center" VerticalAlignment="Center" />
                    </Border>
                    <TextBlock Text="Horario" FontSize="13"
                               Foreground="#5A5A5A" VerticalAlignment="Center" />
                </StackPanel>

                <!-- Paso 3: Asientos -->
                <StackPanel Grid.Column="2" Orientation="Horizontal"
                            HorizontalAlignment="Center" Spacing="10">
                    <Border Width="26" Height="26" CornerRadius="13"
                            Background="#3A3A3A">
                        <TextBlock Text="✓" FontSize="12" FontWeight="Bold"
                                   Foreground="#F5C842"
                                   HorizontalAlignment="Center" VerticalAlignment="Center" />
                    </Border>
                    <TextBlock Text="Asientos" FontSize="13"
                               Foreground="#5A5A5A" VerticalAlignment="Center" />
                </StackPanel>

                <!-- Paso 4: Confirmar (activo) -->
                <StackPanel Grid.Column="3" Orientation="Horizontal"
                            HorizontalAlignment="Center" Spacing="10">
                    <Border Width="26" Height="26" CornerRadius="13"
                            Background="#F5C842" BorderBrush="#3A3A3A" BorderThickness="1">
                        <TextBlock Text="4" FontSize="12" FontWeight="Bold"
                                   Foreground="#0D0D0D"
                                   HorizontalAlignment="Center" VerticalAlignment="Center" />
                    </Border>
                    <TextBlock Text="Confirmar" FontSize="13"
                               Foreground="#F5C842" VerticalAlignment="Center" />
                </StackPanel>
            </Grid>
        </Border>

        <!-- CONTENIDO -->
        <Grid Grid.Row="1" Background="#141414" Padding="36">
            <Border Background="#1A1A1A"
                    CornerRadius="16"
                    Padding="24"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center">
                <StackPanel Spacing="20" HorizontalAlignment="Center">

                    <!-- Encabezado -->
                    <TextBlock Text="🎬 Confirmación de compra"
                               FontSize="20"
                               FontWeight="Bold"
                               Foreground="#F5C842"
                               HorizontalAlignment="Center"/>

                    <!-- Info función -->
                    <TextBlock x:Name="FuncionText"
                               FontSize="14"
                               Foreground="White"
                               TextWrapping="Wrap"
                               TextAlignment="Center"/>

                    <!-- Asientos -->
                    <TextBlock Text="Asientos seleccionados:"
                               FontSize="13"
                               Foreground="#8A8A8A"/>
                    <TextBlock x:Name="AsientosText"
                               FontSize="14"
                               Foreground="White"
                               TextWrapping="Wrap"/>

                    <!-- Total -->
                    <TextBlock Text="Total a pagar:"
                               FontSize="13"
                               Foreground="#8A8A8A"/>
                    <TextBlock x:Name="TotalText"
                               FontSize="18"
                               FontWeight="SemiBold"
                               Foreground="#F5C842"/>

                    <!-- Botones -->
                    <StackPanel Orientation="Horizontal" Spacing="12" HorizontalAlignment="Center">
                        <Button x:Name="BtnFinalizar"
                                Content="✓ Confirmar"
                                Click="BtnFinalizar_Click"
                                Background="#F5C842"
                                Foreground="#0D0D0D"
                                CornerRadius="8"
                                Padding="12,6"/>
                        <Button Content="← Volver"
                                Click="BtnVolver_Click"
                                Background="#2A2A2A"
                                Foreground="White"
                                CornerRadius="8"
                                Padding="12,6"/>
                    </StackPanel>
                </StackPanel>
            </Border>
        </Grid>
    </Grid>
</Page>